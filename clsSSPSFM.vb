    Sub New()
        Pixel = New Double(15964) {}
    End Sub

    Public Sub Read(SourceFilePath As String)

        If Not File.Exists(SourceFilePath) Then
            Throw New FileNotFoundException("SFM.dat file not found.", SourceFilePath)
        End If

        'SFM.datファイルを読み込み、1行ずつ数値を取り出し
        Dim SourceLines As String() = File.ReadAllLines(SourceFilePath)
        For CurrentRow As Integer = 0 To SFMMaxRow
            Dim ValuePosition As Integer = SourceLines(CurrentRow).LastIndexOf(",") + 1
            Pixel(CurrentRow) = CDbl(SourceLines(CurrentRow).Substring(ValuePosition))
        Next
    End Sub

    Sub Write(ByVal DestFilePath As String, OverWriteFlag As Boolean)

        If OverWriteFlag = False And File.Exists(DestFilePath) Then
            Console.WriteLine("The file already exists. Do you want to overwrite it? (Y/N)")
            Dim response As String = Console.ReadLine()
            If response.ToUpper() <> "Y" Then Exit Sub
        End If

        '小数点以下6桁まで担保して、文字列として書き込み
        Using Writer As New StreamWriter(DestFilePath, False, Text.Encoding.GetEncoding("Shift-JIS"))

            '1行ずつ座標と数値を連結して出力
            For CurrentRow As Integer = 0 To SFMMaxRow
                Dim TempString As String = Convert.ToString(Math.Round(Pixel(CurrentRow), 6, MidpointRounding.AwayFromZero))
                TempString = SFMCoordinate(CurrentRow) & TempString
                Writer.WriteLine(TempString)
            Next
        End Using
        'Writer.Close()

    End Sub

    Public Function GetPixels() As Double()
        Return Pixel.Clone()
    End Function

    Public Sub SetPixels(Source As Double())

        Dim SourceSize As Integer = UBound(Source) ' テーブルのサイズ

        ' サイズ検証
        If SourceSize <> SFMMaxRow Then
            Throw New ArgumentException($"入力配列のサイズが不正です。" & vbCrLf &
                                    $"期待されるサイズ: ({SFMMaxRow})" & vbCrLf &
                                    $"実際のサイズ: ({SourceSize})")
        End If

        Pixel = Source.Clone()
    End Sub

End Class

